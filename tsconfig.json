{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./components/server/src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": "./components/server/src",
    "paths": {
      "@providers/*": ["providers/*"],
      "@engine/*": ["engine/*"]
    }
  },
  "include": ["components/server/src"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
