  <!-- ── BW20 — security toolbar: validate + export + import presence ── -->
  <Scenario id="bw20-toolbar-validate" effect="changes-view">
    <Description lang="en">
      Navigate to Security section. Suppress alert (validate is "coming soon" alert).
      Click btn-validate-filters — assert no crash (button still present).
      Click btn-export-filters — intercept createObjectURL to capture JSON — assert non-empty.
      Assert btn-import-filters is present in DOM.
    </Description>
    <Steps>
      <Step action="CLICKID" proc="{{tab}}" path="*[@data-section='security']"
            note="navigate to Security section"/>
      <Step action="WAIT" proc="" value="400" note="section settle"/>

      <!-- suppress alert so validate click doesn't stall the test -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="window._origAlert=window.alert; window.alert=function(){}; 'suppressed'"
            bind="alertSuppressed" note="BW20: suppress window.alert"/>

      <!-- click validate-filters -->
      <Step action="CLICKID" proc="{{tab}}" path="*[@id='btn-validate-filters']"
            note="BW20: click Validate All button (shows suppressed alert)"/>
      <Step action="WAIT" proc="" value="300" note="settle"/>

      <!-- assert validate button is still present (no crash) -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="document.getElementById('btn-validate-filters') !== null ? 1 : 0"
            bind="validateBtnPresent" note="BW20: validate button still in DOM after click"/>
      <Step action="ASSERTPATHEVAL" path="Number('{{validateBtnPresent}}') === 1"
            note="BW20: btn-validate-filters survived click"/>

      <!-- intercept createObjectURL to capture export blob URI -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(function(){ window._exportUrl=null; var orig=URL.createObjectURL; URL.createObjectURL=function(b){ var u=orig.call(URL,b); window._exportUrl=u; return u; }; return 'intercepted'; })()"
            bind="interceptResult" note="BW20: intercept URL.createObjectURL"/>

      <!-- click export-filters -->
      <Step action="CLICKID" proc="{{tab}}" path="*[@id='btn-export-filters']"
            note="BW20: click Export button — triggers exportFilters() → createObjectURL"/>
      <Step action="WAIT" proc="" value="400" note="export settle"/>

      <!-- assert export ran (blob URL was created) -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="window._exportUrl ? window._exportUrl.length : 0"
            bind="exportUrlLen" note="BW20: captured export blob URL length"/>
      <Step action="ASSERTPATHEVAL" path="Number('{{exportUrlLen}}') > 0"
            note="BW20: exportFilters() ran — blob URL created"/>

      <!-- assert btn-import-filters is present -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="document.getElementById('btn-import-filters') !== null ? 1 : 0"
            bind="importBtnPresent" note="BW20: import button present"/>
      <Step action="ASSERTPATHEVAL" path="Number('{{importBtnPresent}}') === 1"
            note="BW20: btn-import-filters is in the DOM"/>

      <!-- restore alert -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="if(window._origAlert)window.alert=window._origAlert; 'restored'"
            bind="alertRestored" note="BW20: restore window.alert"/>
    </Steps>
  </Scenario>

  <!-- ── BW21 — security toolbar: filter-table-toggle round-trip ── -->
  <Scenario id="bw21-toolbar-table-toggle" effect="changes-view">
    <Description lang="en">
      Click btn-filter-table-toggle (Quick-Edit mode on), assert button text changes to contain "Card".
      Click again (back to card mode), assert text reverts to contain "Quick-Edit".
    </Description>
    <Steps>
      <Step action="CLICKID" proc="{{tab}}" path="*[@data-section='security']"
            note="navigate to Security section"/>
      <Step action="WAIT" proc="" value="400" note="section settle"/>

      <!-- ensure we start in card mode (text = Quick-Edit) -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(document.getElementById('btn-filter-table-toggle')||{textContent:''}).textContent"
            bind="toggleBtnInitial" note="BW21: initial button label"/>

      <!-- click once → Quick-Edit mode on -->
      <Step action="CLICKID" proc="{{tab}}" path="*[@id='btn-filter-table-toggle']"
            note="BW21: click Quick-Edit toggle — switch to table mode"/>
      <Step action="WAIT" proc="" value="400" note="table mode render settle"/>

      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(document.getElementById('btn-filter-table-toggle')||{textContent:''}).textContent"
            bind="toggleBtnAfter" note="BW21: button label after first click"/>
      <Step action="ASSERTPATHEVAL" path="'{{toggleBtnAfter}}'.toLowerCase().indexOf('card') >= 0"
            note="BW21: button shows Card View (table mode is active)"/>

      <!-- click again → card mode restored -->
      <Step action="CLICKID" proc="{{tab}}" path="*[@id='btn-filter-table-toggle']"
            note="BW21: click again — restore card view"/>
      <Step action="WAIT" proc="" value="400" note="card mode render settle"/>

      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(document.getElementById('btn-filter-table-toggle')||{textContent:''}).textContent"
            bind="toggleBtnRestored" note="BW21: button label after second click"/>
      <Step action="ASSERTPATHEVAL" path="'{{toggleBtnRestored}}'.toLowerCase().indexOf('quick') >= 0 || '{{toggleBtnRestored}}'.toLowerCase().indexOf('edit') >= 0"
            note="BW21: button shows Quick-Edit (card mode restored)"/>
    </Steps>
  </Scenario>

  <!-- ── BW22 — audit log: refresh + pagesize + autorefresh toggle ── -->
  <Scenario id="bw22-audit-log-controls" effect="changes-view">
    <Description lang="en">
      Navigate to Security section, force-open security-log-panel,
      click Refresh → assert log-list content changed from initial placeholder.
      Change pagesize select to 50 → assert value set.
      Toggle autorefresh checkbox on → assert checked → toggle off → assert unchecked (cleanup).
    </Description>
    <Steps>
      <Step action="CLICKID" proc="{{tab}}" path="*[@data-section='security']"
            note="navigate to Security section"/>
      <Step action="WAIT" proc="" value="400" note="section settle"/>

      <!-- open log panel -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(function(){ var d=document.getElementById('security-log-panel'); if(d&amp;&amp;!d.open){ d.open=true; } return d?'opened':'missing'; })()"
            bind="logPanelOpen" note="BW22: force-open security-log-panel"/>
      <Step action="ASSERTPATHEVAL" path="'{{logPanelOpen}}' !== 'missing'"
            note="BW22: security-log-panel element exists"/>
      <Step action="WAIT" proc="" value="400" note="panel open settle"/>

      <!-- capture initial log list content (placeholder text) -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(document.getElementById('security-log-list')||{innerHTML:''}).innerHTML"
            bind="logListBefore" note="BW22: initial log list HTML"/>

      <!-- click Refresh button (first button inside security-log-panel) -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(function(){ var btn=document.querySelector('#security-log-panel button'); if(btn)btn.click(); return btn?'clicked':'missing'; })()"
            bind="refreshClick" note="BW22: click Refresh button"/>
      <Step action="ASSERTPATHEVAL" path="'{{refreshClick}}' === 'clicked'"
            note="BW22: Refresh button was found and clicked"/>
      <Step action="WAIT" proc="" value="1200" note="loadSecurityLog fetch settle"/>

      <!-- assert log list content changed from initial placeholder -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(document.getElementById('security-log-list')||{innerHTML:''}).innerHTML"
            bind="logListAfter" note="BW22: log list HTML after Refresh"/>
      <Step action="ASSERTPATHEVAL" path="'{{logListAfter}}' !== '{{logListBefore}}'"
            note="BW22: log list content changed after Refresh"/>

      <!-- change pagesize to 50 -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(function(){ var s=document.getElementById('security-log-pagesize'); if(s){s.value='50';s.dispatchEvent(new Event('change'));} return (s||{}).value||''; })()"
            bind="pagesizeVal" note="BW22: set pagesize to 50"/>
      <Step action="ASSERTPATHEVAL" path="'{{pagesizeVal}}' === '50'"
            note="BW22: pagesize select set to 50"/>
      <Step action="WAIT" proc="" value="600" note="log reload with new pagesize"/>

      <!-- toggle autorefresh on -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(function(){ var cb=document.getElementById('security-log-autorefresh'); if(cb){cb.checked=true;cb.dispatchEvent(new Event('change'));} return cb?cb.checked:null; })()"
            bind="autorefreshOn" note="BW22: toggle autorefresh on"/>
      <Step action="ASSERTPATHEVAL" path="String('{{autorefreshOn}}') === 'true'"
            note="BW22: autorefresh checkbox is checked"/>
      <Step action="WAIT" proc="" value="300" note="autorefresh settle"/>

      <!-- toggle autorefresh off (cleanup) -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(function(){ var cb=document.getElementById('security-log-autorefresh'); if(cb){cb.checked=false;cb.dispatchEvent(new Event('change'));} return cb?cb.checked:null; })()"
            bind="autorefreshOff" note="BW22: toggle autorefresh off (cleanup)"/>
      <Step action="ASSERTPATHEVAL" path="String('{{autorefreshOff}}') === 'false'"
            note="BW22: autorefresh checkbox unchecked (cleanup)"/>

      <!-- restore pagesize to 100 (cleanup) -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(function(){ var s=document.getElementById('security-log-pagesize'); if(s){s.value='100';s.dispatchEvent(new Event('change'));} return (s||{}).value||''; })()"
            bind="pagesizeRestored" note="BW22: restore pagesize to 100"/>
    </Steps>
  </Scenario>

  <!-- ── BW23 — btn-save-filters: Save All → REST confirms persistence ── -->
  <Scenario id="bw23-save-filters" effect="changes-view">
    <Description lang="en">
      Navigate to Security section. Read browser-side advancedFilters.length.
      Click btn-save-filters (Save All) — triggers POST /api/filters with current in-memory list.
      Wait for fetch. Then HTTP_FETCH GET /api/filters and assert server count equals browser count.
      No rules are added or removed — this test verifies round-trip persistence only.
    </Description>
    <Parameters>
      <Param name="dashUrl" type="string" required="true"
             example="http://localhost:3458" note="dashboard base URL for HTTP_FETCH"/>
    </Parameters>
    <Steps>
      <Step action="CLICKID" proc="{{tab}}" path="*[@data-section='security']"
            note="navigate to Security section"/>
      <Step action="WAIT" proc="" value="400" note="section settle"/>

      <!-- record browser-side count -->
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="typeof advancedFilters !== 'undefined' ? advancedFilters.length : -1"
            bind="browserCount" note="BW23: browser advancedFilters.length before save"/>
      <Step action="ASSERTPATHEVAL" path="Number('{{browserCount}}') >= 0"
            note="BW23: advancedFilters is accessible in page context"/>

      <!-- click Save All -->
      <Step action="CLICKID" proc="{{tab}}" path="*[@id='btn-save-filters']"
            note="BW23: click Save All Filters button — triggers POST /api/filters"/>
      <Step action="WAIT" proc="" value="1000" note="let saveFilters() fetch complete"/>

      <!-- REST verify: GET /api/filters and check count -->
      <Step action="HTTP_FETCH" proc="{{dashUrl}}/api/filters" path="GET"
            bind="filtersResult" note="BW23: GET /api/filters after save"/>
      <Step action="ASSERTPATHEVAL"
            path="(()=>{ const r=JSON.parse($vars.filtersResult); return r &amp;&amp; r.success === true; })()"
            note="BW23: GET /api/filters returned success:true"/>
      <Step action="ASSERTPATHEVAL"
            path="(()=>{ const r=JSON.parse($vars.filtersResult); const n=(r.filters||[]).length; return n === Number('{{browserCount}}'); })()"
            note="BW23: server filter count equals browser advancedFilters.length"/>
    </Steps>
  </Scenario>

