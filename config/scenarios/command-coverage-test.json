{\n  \"name\": \"Complete Command Coverage Test\",\n  \"description\": \"Test all command types with security filter validation\",\n  \"version\": \"1.0\",\n  \"metadata\": {\n    \"author\": \"AI Assistant\",\n    \"tags\": [\"commands\", \"coverage\", \"security\"]\n  },\n  \"variables\": {\n    \"testApp\": \"calc.exe\",\n    \"testWindow\": \"Calculator\",\n    \"notepadApp\": \"notepad.exe\"\n  },\n  \"steps\": [\n    {\n      \"type\": \"action\",\n      \"action\": \"launch\",\n      \"params\": {\n        \"executable\": \"${testApp}\"\n      },\n      \"description\": \"Launch Calculator (⛔ Process Control)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"wait\",\n      \"duration\": 2000,\n      \"description\": \"Wait for Calculator to open\"\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"queryTree\",\n      \"params\": {\n        \"targetId\": \"${testWindow}\"\n      },\n      \"description\": \"🟢 QUERYTREE: Query Calculator tree (Read Operation)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"listWindows\",\n      \"params\": {},\n      \"description\": \"🟢 LISTWINDOWS: List all windows (Read Operation)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"readProperty\",\n      \"params\": {\n        \"elementId\": \"${testWindow}:{read}\",\n        \"property\": \"Title\"\n      },\n      \"description\": \"🟢 READ: Read Calculator title (Read Operation)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"clickElement\",\n      \"params\": {\n        \"elementId\": \"${testWindow}:{CLICKID:num1Button}\"\n      },\n      \"description\": \"🔴 CLICKID: Click button 1 (UI Interaction)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"clickElement\",\n      \"params\": {\n        \"elementId\": \"${testWindow}:{CLICKNAME:Plus}\"\n      },\n      \"description\": \"🔴 CLICKNAME: Click + button by name (UI Interaction)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"clickElement\",\n      \"params\": {\n        \"elementId\": \"${testWindow}:{CLICK:200,300}\"\n      },\n      \"description\": \"🔴 CLICK: Click at coordinates (UI Interaction)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"action\": \"launch\",\n      \"params\": {\n        \"executable\": \"${notepadApp}\"\n      },\n      \"description\": \"Launch Notepad for text input test\"\n    },\n    {\n      \"type\": \"wait\",\n      \"duration\": 1500\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"sendText\",\n      \"params\": {\n        \"elementId\": \"Notepad:2+2=\",\n        \"text\": \"2+2=\"\n      },\n      \"description\": \"🔴 SENDKEYS: Send text to Notepad (UI Interaction)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"setProperty\",\n      \"params\": {\n        \"elementId\": \"Notepad:{SET:text}\",\n        \"property\": \"Text\",\n        \"value\": \"Test text\"\n      },\n      \"description\": \"🟡 SET: Set text property (Modification)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"action\": \"terminateProcess\",\n      \"params\": {\n        \"process\": \"Notepad\"\n      },\n      \"description\": \"⛔ KILL: Terminate Notepad (Process Control)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"action\": \"terminateProcess\",\n      \"params\": {\n        \"process\": \"Calculator\"\n      },\n      \"description\": \"⛔ KILL: Terminate Calculator (Process Control)\",\n      \"expected\": {\n        \"success\": true\n      }\n    }\n  ],\n  \"assertions\": [\n    {\n      \"description\": \"All command types should be detected and validated\",\n      \"condition\": \"All steps completed successfully\"\n    }\n  ]\n}