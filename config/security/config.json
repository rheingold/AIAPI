{
    "version":  "1.0",
    "security":  {
                     "defaultPolicy":  "DENY_UNLISTED",
                     "requireTargetSignature":  true,
                     "requireOSEnforcement":  false,
                     "expectedCertThumbprint":  null
                 },
    "processes":  {
                      "whitelist":  [
                                        "notepad.exe",
                                        "calc.exe"
                                    ],
                      "blacklist":  [
                                        "cmd.exe",
                                        "powershell.exe"
                                    ]
                  },
    "developmentMode":  {
                            "enabled":  false
                        },
    "filterRules":  [
                        {
                            "action":  "ALLOW",
                            "process":  "notepad.exe",
                            "helper":  "*",
                            "command":  "*",
                            "pattern":  "*",
                            "description":  "Allow all actions on Notepad"
                        },
                        {
                            "action":  "ALLOW",
                            "process":  "calc.exe",
                            "helper":  "*",
                            "command":  "*",
                            "pattern":  "*",
                            "description":  "Allow all actions on Calculator"
                        },
                        {
                            "action":  "DENY",
                            "process":  "*",
                            "helper":  "*",
                            "command":  "LAUNCH",
                            "pattern":  "*",
                            "description":  "Block LAUNCH for all unlisted processes"
                        },
                        {
                            "action":  "DENY",
                            "process":  "*",
                            "helper":  "*",
                            "command":  "KILL",
                            "pattern":  "*",
                            "description":  "Block KILL for all unlisted processes"
                        }
                    ],
