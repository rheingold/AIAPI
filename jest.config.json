{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/components/server/src"],
  "testMatch": ["**/__tests__/**/*.ts", "**/?(*.)+(spec|test).ts"],
  "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json", "node"],
  "moduleNameMapper": {
    "^jsdom$": "<rootDir>/components/server/src/__mocks__/jsdom-mock.js"
  },
  "collectCoverageFrom": [
    "components/server/src/**/*.ts",
    "!components/server/src/**/*.d.ts",
    "!components/server/src/extension.ts"
  ]
}
