      <Step action="WAIT" proc="" value="400" note="section settle"/>
      <Step action="CDP_EXECUTE" proc="{{tab}}"
            value="(function(){ var d=document.getElementById('security-log-panel'); if(d&amp;&amp;!d.open){ d.open=true; } return d?'opened':'missing'; })()"
            bind="logPanelState" note="BW19: force-open security-log-panel details"/>
      <Step action="ASSERTPATHEVAL" path="'{{logPanelState}}' !== 'missing'"
            note="BW19: security-log-panel element exists"/>
      <Step action="WAIT" proc="" value="600" note="log panel open settle"/>
      <Step action="CDP_EXECUTE" proc="{{tab}}"
