{\n  \"name\": \"Security Filter Test Scenario\",\n  \"description\": \"Test security filter validation for various commands\",\n  \"version\": \"1.0\",\n  \"metadata\": {\n    \"author\": \"AI Assistant\",\n    \"tags\": [\"security\", \"validation\", \"test\"]\n  },\n  \"variables\": {\n    \"testWindow\": \"Calculator\"\n  },\n  \"steps\": [\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"queryTree\",\n      \"params\": {\n        \"targetId\": \"${testWindow}\"\n      },\n      \"description\": \"Query Calculator tree (should be allowed - read operation)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\", \n      \"provider\": \"windowsForms\",\n      \"action\": \"clickElement\",\n      \"params\": {\n        \"elementId\": \"Calculator:{CLICKID:buttonOne}\"\n      },\n      \"description\": \"Click Calculator button 1 (should be allowed - normal application)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\", \n      \"action\": \"clickElement\",\n      \"params\": {\n        \"elementId\": \"explorer:{CLICKID:closeButton}\"\n      },\n      \"description\": \"Try to click explorer close button (should be denied - system process)\",\n      \"expected\": {\n        \"success\": false,\n        \"error\": \"Operation blocked by security filter\"\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"readProperty\",\n      \"params\": {\n        \"elementId\": \"Calculator:{READ:title}\",\n        \"property\": \"Text\"\n      },\n      \"description\": \"Read Calculator title (should be allowed - read operation)\",\n      \"expected\": {\n        \"success\": true\n      }\n    },\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"setProperty\",\n      \"params\": {\n        \"elementId\": \"winlogon:{SET:password}\",\n        \"property\": \"Text\", \n        \"value\": \"test\"\n      },\n      \"description\": \"Try to set property on winlogon (should be denied - system process)\",\n      \"expected\": {\n        \"success\": false,\n        \"error\": \"Operation blocked by security filter\"\n      }\n    }\n  ],\n  \"cleanup\": [\n    {\n      \"type\": \"action\",\n      \"provider\": \"windowsForms\",\n      \"action\": \"terminateProcess\",\n      \"params\": {\n        \"processName\": \"Calculator\"\n      },\n      \"description\": \"Close Calculator if still running\"\n    }\n  ]\n}