{
  "scenariosPath": "./scenarios",
  "securityPath": "./security",
  "publicKeyPath": "./security/public.key.enc",
  "privateKeyPath": "./security/private.key.enc",
  "helperPaths": [
    "./dist/helpers"
  ],
  "mcpPort": 3457,
  "logLevel": "debug",
